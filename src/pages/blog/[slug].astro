---
import BlogPost from '../../layouts/BlogPost.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('blog', ({ data }) => !data.draft && data.lang === 'ko');
  const allPosts = await getCollection('blog');

  return posts.map(post => {
    // Try to find matching EN post (replace -ko with -en)
    const enId = post.id.replace(/-ko$/, '-en');
    const enPost = allPosts.find(p => p.id === enId && p.data.lang === 'en');

    return {
      params: { slug: post.id },
      props: { 
        post,
        alternateEn: enPost ? `/en/blog/${enPost.id}/` : '/en/blog/' 
      },
    };
  });
}

const { post, alternateEn } = Astro.props;
const { Content } = await render(post);
---

<BlogPost
  title={post.data.title}
  description={post.data.description}
  date={post.data.date}
  tags={post.data.tags}
  lang="ko"
  slug={post.id}
  alternateEn={alternateEn}
>
  <Content />
</BlogPost>
