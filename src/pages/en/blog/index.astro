---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog', ({ data }) => !data.draft && data.lang === 'en'))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---

<BaseLayout
  title="Technical Blog | 31NS-Tech Hardware Lab"
  description="RF, BLE, NFC, Mixed-Signal hardware engineering technical articles. Antenna tuning, impedance matching, and mass production insights from 31NS-Tech."
  lang="en"
  bodyClass="page-blog"
>
  <section class="hero" style="padding: 100px 0 60px;">
    <div class="container">
      <div class="hero-label">// TECH_BLOG — EN</div>
      <h1>Technical <span class="gold">Blog</span></h1>
      <p>Practical RF &amp; hardware engineering insights and references</p>
    </div>
  </section>

  <style>
    .faq-banner-btn {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 16px;
      padding: 24px;
      background: var(--bg-card);
      border: 1px solid var(--border-color);
      color: var(--gold-primary);
      text-decoration: none;
      transition: all 0.25s ease;
      margin-bottom: 32px;
    }
    .faq-banner-btn:hover {
      border-color: var(--gold-primary);
      background: var(--gold-glow);
      box-shadow: 0 0 20px rgba(255, 221, 124, 0.15);
      transform: translateY(-2px);
    }
    .faq-banner-btn i.fa-arrow-right {
      transition: transform 0.2s ease;
    }
    .faq-banner-btn:hover i.fa-arrow-right {
      transform: translateX(6px);
    }
  </style>

  <section class="section">
    <div class="container">
      <!-- FAQ Link Banner -->
      <a href="/en/rf-faq/" class="faq-banner-btn">
        <i class="fas fa-database" style="font-size: 1.4rem;"></i>
        <span style="font-family: var(--font-mono); font-size: 1.15rem; font-weight: bold; letter-spacing: 2px;">
          View RF Engineering Q&A
        </span>
        <i class="fas fa-arrow-right" style="font-size: 0.95rem;"></i>
      </a>

      {posts.length === 0 ? (
        <div class="data-module">
          <div class="data-module-header">
            <h3>// BLOG_QUEUE.LOG</h3>
            <div class="status"><span class="status-dot"></span> PENDING</div>
          </div>
          <div class="data-module-body">
            <p style="color: var(--text-secondary); font-family: var(--font-mono); font-size: 0.85rem;">
              > Technical articles are being prepared. Check back soon.
            </p>
          </div>
        </div>
      ) : (
        <div class="blog-grid">
          {posts.map(post => (
            <a href={`/en/blog/${post.data.slug.replace(/^en\//, '')}/`} class="blog-card">
              <div class="blog-card-meta">
                <span><i class="fas fa-calendar-alt" style="margin-right:4px;color:var(--gold-primary)"></i>
                  {post.data.date.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
                </span>
              </div>
              <div class="blog-card-title">{post.data.title}</div>
              <div class="blog-card-excerpt">{post.data.description}</div>
              <div class="blog-card-tags">
                {post.data.tags.map((tag: string) => <span class="tag">{tag}</span>)}
              </div>
            </a>
          ))}
        </div>
      )}
    </div>
  </section>
</BaseLayout>
