---
import BlogPost from '../../../layouts/BlogPost.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('blog', ({ data }) => !data.draft && data.lang === 'en');
  const allPosts = await getCollection('blog');

  return posts.map(post => {
    // Try to find matching KO post (replace -en with -ko)
    const koId = post.id.replace(/-en$/, '-ko');
    const koPost = allPosts.find(p => p.id === koId && p.data.lang === 'ko');

    return {
      params: { slug: post.id },
      props: { 
        post,
        alternateKo: koPost ? `/blog/${koPost.id}/` : '/blog/' 
      },
    };
  });
}

const { post, alternateKo } = Astro.props;
const { Content } = await render(post);
---

<BlogPost
  title={post.data.title}
  description={post.data.description}
  date={post.data.date}
  tags={post.data.tags}
  lang="en"
  slug={post.id}
  alternateKo={alternateKo}
>
  <Content />
</BlogPost>
