---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout
  title="About | 31NS-Tech Hardware Lab"
  description="31NS-Tech Hardware Lab is a specialized engineering lab for RF, BLE, NFC, Sensor, and Mixed-Signal hardware development based in South Korea."
  lang="en"
  bodyClass="page-about"
>
  <section class="hero" style="padding: 100px 0 60px;">
    <div class="container">
      <div class="hero-label">// ABOUT — LAB PROFILE</div>
      <h1>About <span class="gold">31NS-Tech</span></h1>
      <p>RF · BLE · NFC · Sensor · Mixed-Signal Hardware Engineering Lab</p>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="section-header">
        <div class="section-tag">LAB OVERVIEW</div>
        <h2>Lab Overview</h2>
      </div>
      <div class="data-module">
        <div class="data-module-header">
          <h3>// LAB_INFO.SYS</h3>
          <div class="status"><span class="status-dot"></span> ACTIVE</div>
        </div>
        <div class="data-module-body">
          <p style="margin-bottom:16px;">
            31NS-Tech Hardware Lab is an engineering lab specializing in
            <span class="highlight">RF · BLE · NFC · Sensor · Mixed-Signal circuit and product development</span>.
          </p>
          <p>
            Drawing on 20 years of real-world industry experience, we handle every phase of product
            development directly — circuit design, firmware collaboration, RF tuning,
            mass production support, and certification compliance.
          </p>
        </div>
      </div>
    </div>
  </section>

  <section class="section section--alt">
    <div class="container">
      <div class="section-header">
        <div class="section-tag">ENGINEER PROFILE</div>
        <h2>Engineer Profile</h2>
      </div>
      <div class="grid-2">
        <div class="card">
          <h3><i class="fas fa-user-shield" style="color:var(--gold-primary);margin-right:8px;"></i>Key Experience</h3>
          <ul>
            <li>RF-BLE-NFC hardware specialist</li>
            <li>RF design experience with Samsung, LG, and other major Korean conglomerates</li>
            <li>Mixed-Signal Analog Front-End development</li>
            <li>Monitoring sensor board development for semiconductor &amp; display production lines</li>
          </ul>
        </div>
        <div class="card">
          <h3><i class="fas fa-certificate" style="color:var(--gold-primary);margin-right:8px;"></i>Expertise</h3>
          <ul>
            <li>Diverse electronic circuit &amp; PCB design</li>
            <li>Mass production management &amp; process troubleshooting</li>
            <li>Functional, performance, reliability &amp; environmental testing</li>
            <li>KC/FCC/CE non-conformance resolution</li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="section-header">
        <div class="section-tag">SPECIALIZATION</div>
        <h2>Specialization Areas</h2>
      </div>
      <div class="grid-2">
        <div class="card">
          <i class="fas fa-satellite-dish card-icon"></i>
          <h3>RF &amp; Wireless</h3>
          <ul>
            <li>2.4GHz ISM Band RF circuit design &amp; optimization</li>
            <li>Nordic-based BLE module HW development &amp; tuning</li>
            <li>13.56MHz + 125kHz dual NFC circuit design</li>
            <li>Impedance matching · antenna tuning · RF optimization</li>
          </ul>
        </div>
        <div class="card">
          <i class="fas fa-microchip card-icon"></i>
          <h3>Sensor &amp; Mixed-Signal</h3>
          <ul>
            <li>Mixed-Signal sensor board development</li>
            <li>High-voltage/current control circuit design</li>
            <li>Piezo-based 96dB+ high-output sound circuit &amp; structure</li>
            <li>Ultrasonic transducer-based concrete hardness/strength measurement equipment</li>
          </ul>
        </div>
        <div class="card">
          <i class="fas fa-lightbulb card-icon"></i>
          <h3>Optics &amp; Miniature</h3>
          <ul>
            <li>Motion-triggered flash &amp; high-power LED flash circuits</li>
            <li>Ultra-compact build-up PCB multi-sensor AFE integrated module design</li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <section class="section section--alt">
    <div class="container">
      <div class="section-header" style="text-align:center;">
        <div class="section-tag" style="display:inline-block;">MISSION</div>
        <h2>Lab Mission</h2>
      </div>
      <div class="data-module">
        <div class="data-module-header">
          <h3>// MISSION_STATEMENT.LOG</h3>
          <div class="status"><span class="status-dot"></span> COMMITTED</div>
        </div>
        <div class="data-module-body" style="text-align:center;">
          <p style="margin-bottom:16px;font-size:1.05rem;color:var(--text-primary);">
            Our goal is not simply to design circuits —<br>
            it is to <span class="highlight">clearly solve your problems through technology</span>.
          </p>
          <p style="color:var(--text-secondary);">
            We approach every project with a hands-on mindset, ensuring that even complex circuit
            architectures translate into measurable, understandable performance improvements.
          </p>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
