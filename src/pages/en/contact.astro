---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Contact Us | Hardware Development & RF Consulting Inquiries"
  description="Contact 31NS-Tech for total hardware engineering solutions: RF circuit design, BLE antenna matching, KC/FCC certification, and mass production consulting."
  lang="en"
  bodyClass="page-contact"
>
  <section class="hero" style="padding: 100px 0 60px;">
    <div class="container">
      <div class="hero-label">// CONTACT — OPEN CHANNEL</div>
      <h1><span class="gold">Contact</span></h1>
      <p>Project Inquiry · Technical Consultation · Collaboration</p>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="grid-3" style="grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));">
        <div class="card">
          <i class="fas fa-envelope-open-text card-icon"></i>
          <h3>Inquiry Guide</h3>
          <p>
            31NS-Tech Hardware Lab handles hands-on engineering projects based on
            RF · BLE · NFC · Sensor · Mixed-Signal hardware.
          </p>
          <p style="margin-top:12px;font-size:0.85rem;">
            For circuit design, RF tuning, product development, certification compliance,
            or mass production support — reach us at the contact info below.
          </p>
        </div>
        <div class="card">
          <i class="fas fa-address-card card-icon"></i>
          <h3>Contact Information</h3>
          <ul>
            <li><i class="fas fa-envelope" style="color:var(--gold-primary);margin-right:8px;"></i> promisesmk@gmail.com</li>
            <li><i class="fas fa-envelope" style="color:var(--gold-primary);margin-right:8px;"></i> nskim@31ns.kr</li>
            <li><i class="fas fa-map-marker-alt" style="color:var(--gold-primary);margin-right:8px;"></i> Gwangmyeong-si, Gyeonggi-do, South Korea</li>
          </ul>
        </div>
        <div class="card">
          <i class="fas fa-clipboard-list card-icon"></i>
          <h3>What to Prepare</h3>
          <ul>
            <li>Summary of required functionality or issue</li>
            <li>Operating environment details (temperature, power, range, RF conditions, etc.)</li>
            <li>Expected timeline / target specifications</li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <section class="section section--alt">
    <div class="container">
      <div class="section-header">
        <div class="section-tag">TECH KEYWORDS</div>
        <h2>Key Technology Keywords</h2>
        <p>Referencing these keywords in your inquiry helps us respond more efficiently.</p>
      </div>

      <div class="data-module" style="margin-bottom:24px;">
        <div class="data-module-header">
          <h3>// KEYWORD_MATRIX.DB</h3>
          <div class="status"><span class="status-dot"></span> INDEXED</div>
        </div>
        <div class="data-module-body" style="overflow-x:auto;padding:0;">
          <table class="keyword-table">
            <thead><tr><th>Category</th><th>Keywords</th></tr></thead>
            <tbody>
              <tr><th>RF / Wireless</th><td>RF hardware development, BLE, NFC, 2.4GHz RF, Nordic BLE module, RF circuit design, RF output tuning, antenna tuning, impedance matching, 2.4G pattern antenna design</td></tr>
              <tr><th>Circuit / PCB Design</th><td>PCB design, build-up PCB design, electronic circuit CAD, digital circuit, analog circuit, Mixed-Signal AFE, industrial sensor circuit, high-voltage/current control</td></tr>
              <tr><th>Components / Modules</th><td>Ultrasonic sensor, piezo sound, LED flash circuit</td></tr>
              <tr><th>Certification / Production</th><td>KC/FCC/CE certification, mass production management, DFM (design for manufacturability)</td></tr>
              <tr><th>Software</th><td>Firmware development, embedded software</td></tr>
              <tr><th>Services</th><td>Technical consultation, hardware development inquiry</td></tr>
            </tbody>
          </table>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
