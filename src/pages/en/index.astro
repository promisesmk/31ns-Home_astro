---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout
  title="31NS-Tech Hardware Lab | RF BLE NFC Hardware Engineering"
  description="Expert RF, BLE, NFC, and Mixed-Signal hardware design lab. 20+ years of experience in circuit design, antenna tuning, PCB layout, mass production, and KC/FCC/CE certification — 31NS-Tech Hardware Lab, South Korea."
  lang="en"
  bodyClass="page-index"
>
  <script type="application/ld+json" is:raw>
  {
    "@context": "https://schema.org",
    "@type": "ProfessionalService",
    "name": "31NS-Tech Hardware Lab",
    "url": "https://31ns.kr/en",
    "description": "Expert RF, BLE, NFC, and Mixed-Signal hardware engineering lab specializing in circuit design, antenna tuning, PCB layout, mass production, and certification.",
    "address": {
      "@type": "PostalAddress",
      "addressLocality": "Gwangmyeong-si",
      "addressRegion": "Gyeonggi-do",
      "addressCountry": "KR"
    },
    "email": "nskim@31ns.kr",
    "areaServed": ["KR", "US", "GLOBAL"],
    "serviceType": ["RF Circuit Design", "BLE Module Development", "NFC Hardware", "PCB Design", "KC/FCC/CE Certification"]
  }
  </script>

  <!-- HERO -->
  <section class="hero">
    <div class="container">
      <div class="hero-content">
        <div class="hero-text">
          <div class="hero-label">// HARDWARE LAB — TOTAL ENGINEERING SOLUTION</div>
          <h1>
            From Circuit Design to Mass Production —<br>
            <span class="gold">Proven Expertise</span><br>
            for Successful Product Development
          </h1>
          <p>
            <strong style="color: var(--gold-primary)">RF · BLE · NFC · Mixed-Signal</strong><br>
            Built on 20+ years of hands-on RF and Mixed-Signal experience,
            we are the engineering partner that accelerates your development timeline
            and maximizes mass-production success rates.
          </p>
          <div style="display: flex; gap: 16px; flex-wrap: wrap;">
            <a href="/en/contact/" class="btn"><i class="fas fa-terminal"></i> Request Consultation</a>
            <a href="/en/services/" class="btn btn-outline"><i class="fas fa-microchip"></i> View Services</a>
          </div>
          <div class="hero-stats">
            <div class="stat-item"><span class="stat-value">20+</span><span class="stat-label">Years of Experience</span></div>
            <div class="stat-item"><span class="stat-value">RF/BLE/NFC</span><span class="stat-label">Core Specialization</span></div>
            <div class="stat-item"><span class="stat-value">KC·FCC·CE</span><span class="stat-label">Certification Support</span></div>
            <div class="stat-item"><span class="stat-value">E2E</span><span class="stat-label">Design to Production</span></div>
          </div>
        </div>

        <div class="hero-video">
          <div class="video-terminal" style="width:190px;">
            <div class="video-terminal-header">
              <span>MECH_FEED</span>
              <div class="vid-status"><span class="status-dot"></span> LIVE</div>
            </div>
            <div class="video-wrapper">
              <video src="/assets/mech_feed.mp4" autoplay loop muted playsinline></video>
            </div>
          </div>
          <div class="video-terminal" style="width:190px;">
            <div class="video-terminal-header">
              <span>VIBE_FEED</span>
              <div class="vid-status"><span class="status-dot"></span> LIVE</div>
            </div>
            <div class="video-wrapper">
              <video src="/assets/vibe_feed.mp4" autoplay loop muted playsinline></video>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- PHILOSOPHY -->
  <section class="section">
    <div class="container">
      <div class="section-header">
        <div class="section-tag">PHILOSOPHY</div>
        <h2>Engineering Philosophy</h2>
        <p>Rooted in hands-on experience — solving your hardware challenges with clarity.</p>
      </div>
      <div class="data-module">
        <div class="data-module-header">
          <h3>// LAB_MISSION.LOG</h3>
          <div class="status"><span class="status-dot"></span> ACTIVE</div>
        </div>
        <div class="data-module-body">
          <p style="font-size:1.05rem;margin-bottom:16px;color:var(--text-primary);">
            31NS-Tech Hardware Lab leverages 20+ years of RF and Mixed-Signal expertise to
            shorten your development cycles and maximize mass-production success rates as
            your dedicated engineering partner.
          </p>
          <p style="color:var(--gold-primary);font-weight:600;font-family:var(--font-mono);font-size:0.9rem;">
            > Delivering high-reliability hardware solutions validated under extreme conditions is our core philosophy.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- CORE CAPABILITIES -->
  <section class="section section--alt">
    <div class="container">
      <div class="section-header">
        <div class="section-tag">CORE CAPABILITIES</div>
        <h2>Core Capabilities</h2>
        <p>Differentiated expertise in RF/wireless and precision sensor hardware</p>
      </div>
      <div class="grid-2">
        <div class="card">
          <i class="fas fa-satellite-dish card-icon"></i>
          <h3>RF &amp; Wireless Optimization</h3>
          <p>Maximize communication performance through 2.4GHz RF, BLE, NFC circuit design, impedance matching, and VNA-based antenna tuning.</p>
          <ul><li>2.4GHz RF transceiver circuit design</li><li>Impedance matching / antenna matching</li><li>Noise suppression &amp; EMI mitigation</li></ul>
          <a href="/en/rf-faq/" class="btn btn-outline" style="margin-top: 16px; padding: 6px 12px; font-size: 0.8rem; display: inline-flex; align-items: center; gap: 6px; width: fit-content; text-transform: uppercase; font-family: var(--font-mono);">
            <i class="fas fa-database"></i> View RF Q&As
          </a>
        </div>
        <div class="card">
          <i class="fas fa-microchip card-icon"></i>
          <h3>Mixed-Signal &amp; AFE</h3>
          <p>Design noise-immune analog front-end (AFE) and sensor interfaces to ensure measurement reliability in harsh environments.</p>
          <ul><li>Analog front-end (AFE) design</li><li>High-resolution sensor interfaces</li><li>Signal amplification / filtering / ADC optimization</li></ul>
        </div>
        <div class="card">
          <i class="fas fa-industry card-icon"></i>
          <h3>Mass Production &amp; Certification</h3>
          <p>Full lifecycle support: DFM, BOM optimization, production line troubleshooting, and KC/FCC/CE certification guidance.</p>
          <ul><li>DFM design for manufacturability</li><li>Optimized BOM configuration</li><li>KC/FCC/CE certification guidance</li></ul>
        </div>
        <div class="card">
          <i class="fas fa-code card-icon"></i>
          <h3>💻 Dev Vibe Coding</h3>
          <p>Research and development of AI-driven applications using natural language prompt engineering for Web, App, and YouTube.</p>
          <ul><li>Natural language prompt engineering</li><li>Intelligent service integration</li><li>Web/App/YouTube Vibe design</li></ul>
        </div>
      </div>
    </div>
  </section>

  <!-- BLOG PREVIEW -->
  <section class="section">
    <div class="container">
      <div class="section-header">
        <div class="section-tag">TECH BLOG</div>
        <h2>Technical Blog</h2>
        <p>Practical RF and hardware engineering insights and technical references.</p>
      </div>
      <div style="text-align:center;margin-top:32px;">
        <a href="/en/blog/" class="btn btn-outline"><i class="fas fa-book-open"></i> View Technical Articles</a>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="section section--alt" style="text-align:center;">
    <div class="container">
      <div class="section-header" style="text-align:center;">
        <div class="section-tag" style="display:inline-block;">REQUEST</div>
        <h2>Project Inquiry &amp; Technical Consultation</h2>
        <p style="margin:12px auto 0;">Facing a tough hardware challenge? Contact 31NS-Tech Hardware Lab.</p>
      </div>
      <div style="margin-top:32px;">
        <a href="/en/contact/" class="btn"><i class="fas fa-envelope"></i> Get a Quote or Consultation</a>
      </div>
    </div>
  </section>
</BaseLayout>
