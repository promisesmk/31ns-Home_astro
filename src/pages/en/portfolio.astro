---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Portfolio | 31NS-Tech Hardware Lab"
  description="31NS-Tech Hardware Lab project portfolio: BLE temperature monitoring, firefighter PASS alarm, Mixed-Signal sensor boards, NFC dual antenna, BLE module development."
  lang="en"
  bodyClass="page-portfolio"
>
  <section class="hero" style="padding: 100px 0 60px;">
    <div class="container">
      <div class="hero-label">// PORTFOLIO — PROJECT ARCHIVE</div>
      <h1>Project <span class="gold">Portfolio</span></h1>
      <p>Recent major hardware development case studies</p>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="section-header">
        <div class="section-tag">PROJECT ARCHIVE</div>
        <h2>Key Development Cases</h2>
      </div>

      <div class="data-module" style="margin-bottom:20px;">
        <div class="data-module-header">
          <h3>// PROJECT_000 — PREDICTIVE MAINT</h3>
          <div class="status"><span class="status-dot"></span> MASS_PROD</div>
        </div>
        <div class="data-module-body">
          <h3 style="font-family:var(--font-ui);font-size:1.1rem;color:var(--text-primary);margin-bottom:12px;">Condition Monitoring &amp; Predictive Maintenance</h3>
          <p style="font-size:0.9rem;color:var(--text-secondary);margin-bottom:16px;">Multi-sensor integration with ultra-compact form factor design. Mass production supply completed for major Korean enterprises (Samsung, LG).</p>
          <div class="grid-2" style="gap:12px;">
            <div style="font-family:var(--font-mono);font-size:0.8rem;color:var(--text-secondary);padding-left:16px;position:relative;"><span style="position:absolute;left:0;color:var(--gold-primary);">›</span> Ultra-compact custom form factor design</div>
            <div style="font-family:var(--font-mono);font-size:0.8rem;color:var(--text-secondary);padding-left:16px;position:relative;"><span style="position:absolute;left:0;color:var(--gold-primary);">›</span> Industrial multi-sensor optimized integration</div>
            <div style="font-family:var(--font-mono);font-size:0.8rem;color:var(--text-secondary);padding-left:16px;position:relative;"><span style="position:absolute;left:0;color:var(--gold-primary);">›</span> Hybrid communication interface support</div>
            <div style="font-family:var(--font-mono);font-size:0.8rem;color:var(--text-secondary);padding-left:16px;position:relative;"><span style="position:absolute;left:0;color:var(--gold-primary);">›</span> B2B mass production &amp; quality verification</div>
          </div>
        </div>
      </div>

      <div class="data-module" style="margin-bottom:20px;">
        <div class="data-module-header">
          <h3>// PROJECT_001 — BLE TEMP MONITOR</h3>
          <div class="status"><span class="status-dot"></span> DEPLOYED</div>
        </div>
        <div class="data-module-body">
          <h3 style="font-family:var(--font-ui);font-size:1.1rem;color:var(--text-primary);margin-bottom:12px;">COVID-19 BLE Temperature Monitoring Device</h3>
          <p style="font-size:0.9rem;color:var(--text-secondary);margin-bottom:16px;">BLE-based low-power temperature monitoring device deployed in national disaster response. Designed for stable operation in extreme cold (-20°C to -70°C).</p>
          <div class="grid-2" style="gap:12px;">
            <div style="font-family:var(--font-mono);font-size:0.8rem;color:var(--text-secondary);padding-left:16px;position:relative;"><span style="position:absolute;left:0;color:var(--gold-primary);">›</span> BLE module (Nordic nRF52 Series)</div>
            <div style="font-family:var(--font-mono);font-size:0.8rem;color:var(--text-secondary);padding-left:16px;position:relative;"><span style="position:absolute;left:0;color:var(--gold-primary);">›</span> External temperature sensing probe interface</div>
            <div style="font-family:var(--font-mono);font-size:0.8rem;color:var(--text-secondary);padding-left:16px;position:relative;"><span style="position:absolute;left:0;color:var(--gold-primary);">›</span> Ultra-low-power firmware architecture</div>
            <div style="font-family:var(--font-mono);font-size:0.8rem;color:var(--text-secondary);padding-left:16px;position:relative;"><span style="position:absolute;left:0;color:var(--gold-primary);">›</span> KC certification &amp; mass production supply</div>
          </div>
        </div>
      </div>

      <div class="data-module" style="margin-bottom:20px;">
        <div class="data-module-header">
          <h3>// PROJECT_002 — PASS ALARM</h3>
          <div class="status"><span class="status-dot"></span> DEPLOYED</div>
        </div>
        <div class="data-module-body">
          <h3 style="font-family:var(--font-ui);font-size:1.1rem;color:var(--text-primary);margin-bottom:12px;">Firefighter Personal Alert Safety System (PASS)</h3>
          <p style="font-size:0.9rem;color:var(--text-secondary);margin-bottom:16px;">High-output alarm (96dB) + waterproof life-safety device for firefighters. Extreme environment design for shock/vibration/high-heat conditions.</p>
          <div class="grid-2" style="gap:12px;">
            <div style="font-family:var(--font-mono);font-size:0.8rem;color:var(--text-secondary);padding-left:16px;position:relative;"><span style="position:absolute;left:0;color:var(--gold-primary);">›</span> Piezo + resonance chamber alarm structure</div>
            <div style="font-family:var(--font-mono);font-size:0.8rem;color:var(--text-secondary);padding-left:16px;position:relative;"><span style="position:absolute;left:0;color:var(--gold-primary);">›</span> OLED status display &amp; sensor integration</div>
            <div style="font-family:var(--font-mono);font-size:0.8rem;color:var(--text-secondary);padding-left:16px;position:relative;"><span style="position:absolute;left:0;color:var(--gold-primary);">›</span> Extreme durability (IP67 waterproof)</div>
            <div style="font-family:var(--font-mono);font-size:0.8rem;color:var(--text-secondary);padding-left:16px;position:relative;"><span style="position:absolute;left:0;color:var(--gold-primary);">›</span> KC certification &amp; fire safety standards compliance</div>
          </div>
        </div>
      </div>

      <div class="data-module" style="margin-bottom:20px;">
        <div class="data-module-header">
          <h3>// PROJECT_003 — NFC DUAL ANTENNA</h3>
          <div class="status"><span class="status-dot"></span> COMPLETED</div>
        </div>
        <div class="data-module-body">
          <h3 style="font-family:var(--font-ui);font-size:1.1rem;color:var(--text-primary);margin-bottom:12px;">NFC Dual-Frequency Antenna System</h3>
          <p style="font-size:0.9rem;color:var(--text-secondary);margin-bottom:16px;">Combined NFC system supporting 125kHz + 13.56MHz simultaneously in a single reader.</p>
          <div class="grid-2" style="gap:12px;">
            <div style="font-family:var(--font-mono);font-size:0.8rem;color:var(--text-secondary);padding-left:16px;position:relative;"><span style="position:absolute;left:0;color:var(--gold-primary);">›</span> Dual coil layout optimization</div>
            <div style="font-family:var(--font-mono);font-size:0.8rem;color:var(--text-secondary);padding-left:16px;position:relative;"><span style="position:absolute;left:0;color:var(--gold-primary);">›</span> Inter-frequency notch filter design</div>
            <div style="font-family:var(--font-mono);font-size:0.8rem;color:var(--text-secondary);padding-left:16px;position:relative;"><span style="position:absolute;left:0;color:var(--gold-primary);">›</span> Independent matching network configuration</div>
            <div style="font-family:var(--font-mono);font-size:0.8rem;color:var(--text-secondary);padding-left:16px;position:relative;"><span style="position:absolute;left:0;color:var(--gold-primary);">›</span> Ferrite shielding for metal environments</div>
          </div>
        </div>
      </div>

      <div class="data-module">
        <div class="data-module-header">
          <h3>// PROJECT_004 — ULTRASONIC SENSOR</h3>
          <div class="status"><span class="status-dot"></span> COMPLETED</div>
        </div>
        <div class="data-module-body">
          <h3 style="font-family:var(--font-ui);font-size:1.1rem;color:var(--text-primary);margin-bottom:12px;">Ultrasonic Concrete Strength Measurement Equipment</h3>
          <p style="font-size:0.9rem;color:var(--text-secondary);margin-bottom:16px;">Non-destructive concrete hardness and compressive strength measurement using ultrasonic transducers.</p>
          <div class="grid-2" style="gap:12px;">
            <div style="font-family:var(--font-mono);font-size:0.8rem;color:var(--text-secondary);padding-left:16px;position:relative;"><span style="position:absolute;left:0;color:var(--gold-primary);">›</span> Ultrasonic transducer drive circuit</div>
            <div style="font-family:var(--font-mono);font-size:0.8rem;color:var(--text-secondary);padding-left:16px;position:relative;"><span style="position:absolute;left:0;color:var(--gold-primary);">›</span> High-speed ADC ToF measurement</div>
            <div style="font-family:var(--font-mono);font-size:0.8rem;color:var(--text-secondary);padding-left:16px;position:relative;"><span style="position:absolute;left:0;color:var(--gold-primary);">›</span> Signal filtering &amp; noise suppression</div>
            <div style="font-family:var(--font-mono);font-size:0.8rem;color:var(--text-secondary);padding-left:16px;position:relative;"><span style="position:absolute;left:0;color:var(--gold-primary);">›</span> Field-use portable form factor design</div>
          </div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
