---
import BlogPost from '../../../layouts/BlogPost.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('blog', ({ data }) => !data.draft && data.lang === 'en');
  const allPosts = await getCollection('blog');

  return posts.map(post => {
    // Strip 'en/' prefix to get a clean slug (e.g. 'en/my-post' → 'my-post')
    const slug = post.id.replace(/^en\//, '');

    // Find matching KO post by comparing clean slugs
    const koPost = allPosts.find(p =>
      p.data.lang === 'ko' &&
      p.id.replace(/^ko\//, '') === slug
    );

    return {
      params: { slug },
      props: {
        post,
        alternateKo: koPost ? `/blog/${koPost.id.replace(/^ko\//, '')}/` : '/blog/',
      },
    };
  });
}

const { post, alternateKo } = Astro.props;
const { Content } = await render(post);
---

<BlogPost
  title={post.data.title}
  description={post.data.description}
  date={post.data.date}
  tags={post.data.tags}
  lang="en"
  slug={post.id.replace(/^en\//, '')}
  alternateKo={alternateKo}
>
  <Content />
</BlogPost>
