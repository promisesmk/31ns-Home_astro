---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog', ({ data }) => !data.draft && data.lang === 'ko'))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---

<BaseLayout
  title="기술 블로그 | 31NS-Tech Hardware Lab"
  description="RF, BLE, NFC, Mixed-Signal 하드웨어 개발 실전 기술 자료. 안테나 튜닝, 임피던스 매칭, 양산 노하우를 공유합니다."
  lang="ko"
  bodyClass="page-blog"
>
  <section class="hero" style="padding: 100px 0 60px;">
    <div class="container">
      <div class="hero-label">// TECH_BLOG — KO</div>
      <h1>기술 <span class="gold">블로그</span></h1>
      <p>RF/하드웨어 개발 실전 노하우와 기술 자료</p>
    </div>
  </section>

  <section class="section">
    <div class="container">
      {posts.length === 0 ? (
        <div class="data-module">
          <div class="data-module-header">
            <h3>// BLOG_QUEUE.LOG</h3>
            <div class="status"><span class="status-dot"></span> PENDING</div>
          </div>
          <div class="data-module-body">
            <p style="color: var(--text-secondary); font-family: var(--font-mono); font-size: 0.85rem;">
              > 기술 자료가 준비 중입니다. 곧 업로드될 예정입니다.
            </p>
          </div>
        </div>
      ) : (
        <div class="blog-grid">
          {posts.map(post => (
            <a href={`/blog/${post.id.replace(/^ko\//, '')}/`} class="blog-card">
              <div class="blog-card-meta">
                <span><i class="fas fa-calendar-alt" style="margin-right:4px;color:var(--gold-primary)"></i>
                  {post.data.date.toLocaleDateString('ko-KR', { year: 'numeric', month: 'long', day: 'numeric' })}
                </span>
              </div>
              <div class="blog-card-title">{post.data.title}</div>
              <div class="blog-card-excerpt">{post.data.description}</div>
              <div class="blog-card-tags">
                {post.data.tags.map((tag: string) => <span class="tag">{tag}</span>)}
              </div>
            </a>
          ))}
        </div>
      )}
    </div>
  </section>
</BaseLayout>
