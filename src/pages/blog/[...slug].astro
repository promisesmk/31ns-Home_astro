---
import BlogPost from '../../layouts/BlogPost.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('blog', ({ data }) => !data.draft && data.lang === 'ko');
  const allPosts = await getCollection('blog');

  return posts.map(post => {
    const slug = post.data.slug;

    // Find matching EN post by comparing clean slugs
    const enPost = allPosts.find(p =>
      p.data.lang === 'en' &&
      p.data.slug.replace(/^en\//, '') === slug
    );

    return {
      params: { slug },
      props: {
        post,
        alternateEn: enPost ? `/en/blog/${enPost.data.slug.replace(/^en\//, '')}/` : '/en/blog/',
      },
    };
  });
}

const { post, alternateEn } = Astro.props;
const { Content } = await render(post);
---

<BlogPost
  title={post.data.title}
  description={post.data.description}
  date={post.data.date}
  tags={post.data.tags}
  lang="ko"
  slug={post.data.slug}
  alternateEn={alternateEn}
>
  <Content />
</BlogPost>
