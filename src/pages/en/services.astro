---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Services | RF Design, BLE Antenna Matching, Compliance Certification"
  description="Explore engineering services by 31NS-Tech: 2.4GHz RF design, BLE antenna matching & VNA tuning, NFC hardware, environmental reliability tests, and KC/FCC/CE compliance consulting."
  lang="en"
  bodyClass="page-services"
>
  <section class="hero" style="padding: 100px 0 60px;">
    <div class="container">
      <div class="hero-label">// SERVICES — ENGINEERING CAPABILITIES</div>
      <h1>Engineering <span class="gold">Services</span></h1>
      <p>RF · BLE · NFC · Sensor · Mixed-Signal hands-on engineering services</p>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="section-header">
        <div class="section-tag">SERVICE OVERVIEW</div>
        <h2>Core Services</h2>
      </div>
      <div class="grid-3">
        <div class="card"><i class="fas fa-broadcast-tower card-icon"></i><h3>RF · BLE · NFC Hardware Development</h3></div>
        <div class="card"><i class="fas fa-wave-square card-icon"></i><h3>Mixed-Signal Analog Front-End Design</h3></div>
        <div class="card"><i class="fab fa-bluetooth-b card-icon"></i><h3>BLE RF Circuit Design &amp; Antenna Matching</h3></div>
        <div class="card"><i class="fas fa-thermometer-half card-icon"></i><h3>Industrial Sensor System Development</h3></div>
        <div class="card"><i class="fas fa-cogs card-icon"></i><h3>Mass Production Troubleshooting &amp; Process Optimization</h3></div>
        <div class="card"><i class="fas fa-shield-alt card-icon"></i><h3>KC / FCC / CE Certification Technical Support</h3></div>
      </div>
    </div>
  </section>

  <section class="section section--alt">
    <div class="container">
      <div class="section-header">
        <div class="section-tag">DETAILED SPECS</div>
        <h2>Service Details</h2>
      </div>

      <div class="grid-2" style="margin-bottom:20px;">
        <div class="data-module">
          <div class="data-module-header">
            <h3>// RF_TUNING.SVC</h3>
            <div class="status"><span class="status-dot"></span> OPERATIONAL</div>
          </div>
          <div class="data-module-body">
            <h3 style="font-family:var(--font-ui);font-size:1.1rem;color:var(--text-primary);margin-bottom:12px;">
              <i class="fas fa-satellite-dish" style="color:var(--gold-primary);margin-right:8px;"></i>RF Design &amp; Tuning
            </h3>
            <p style="margin-bottom:16px;font-size:0.9rem;color:var(--text-secondary);">
              <span class="highlight">2.4GHz ISM Band RF circuit design and RF tuning specialist</span>.
              Full RF optimization from spectrum analysis to chamber antenna matching.
            </p>
            <ul style="padding-left:0;list-style:none;">
              <li style="font-family:var(--font-mono);font-size:0.8rem;color:var(--text-secondary);margin-bottom:8px;padding-left:16px;position:relative;"><span style="position:absolute;left:0;color:var(--gold-primary);">›</span> 2.4GHz RF transceiver circuit design</li>
              <li style="font-family:var(--font-mono);font-size:0.8rem;color:var(--text-secondary);margin-bottom:8px;padding-left:16px;position:relative;"><span style="position:absolute;left:0;color:var(--gold-primary);">›</span> Impedance matching / antenna matching (S11, VNA)</li>
              <li style="font-family:var(--font-mono);font-size:0.8rem;color:var(--text-secondary);margin-bottom:8px;padding-left:16px;position:relative;"><span style="position:absolute;left:0;color:var(--gold-primary);">›</span> Noise suppression &amp; EMI improvement</li>
              <li style="font-family:var(--font-mono);font-size:0.8rem;color:var(--text-secondary);margin-bottom:8px;padding-left:16px;position:relative;"><span style="position:absolute;left:0;color:var(--gold-primary);">›</span> PA / LNA / filter tuning</li>
            </ul>
            <a href="/en/rf-faq/" class="btn btn-outline" style="margin-top: 16px; padding: 6px 12px; font-size: 0.8rem; display: inline-flex; align-items: center; gap: 6px; width: fit-content; text-transform: uppercase; font-family: var(--font-mono);">
              <i class="fas fa-database"></i> View RF Design Q&As
            </a>
          </div>
        </div>

        <div class="data-module">
          <div class="data-module-header">
            <h3>// BLE_WIRELESS.SVC</h3>
            <div class="status"><span class="status-dot"></span> OPERATIONAL</div>
          </div>
          <div class="data-module-body">
            <h3 style="font-family:var(--font-ui);font-size:1.1rem;color:var(--text-primary);margin-bottom:12px;">
              <i class="fab fa-bluetooth-b" style="color:var(--gold-primary);margin-right:8px;"></i>BLE / Wireless Hardware
            </h3>
            <p style="margin-bottom:16px;font-size:0.9rem;color:var(--text-secondary);">
              Nordic-based BLE device circuit design and module development. Extensive experience with nRF52 low-power product development.
            </p>
            <ul style="padding-left:0;list-style:none;">
              <li style="font-family:var(--font-mono);font-size:0.8rem;color:var(--text-secondary);margin-bottom:8px;padding-left:16px;position:relative;"><span style="position:absolute;left:0;color:var(--gold-primary);">›</span> Nordic nRFxx-based circuit design</li>
              <li style="font-family:var(--font-mono);font-size:0.8rem;color:var(--text-secondary);margin-bottom:8px;padding-left:16px;position:relative;"><span style="position:absolute;left:0;color:var(--gold-primary);">›</span> Antenna performance tuning &amp; power optimization</li>
              <li style="font-family:var(--font-mono);font-size:0.8rem;color:var(--text-secondary);margin-bottom:8px;padding-left:16px;position:relative;"><span style="position:absolute;left:0;color:var(--gold-primary);">›</span> Custom BLE module design</li>
              <li style="font-family:var(--font-mono);font-size:0.8rem;color:var(--text-secondary);margin-bottom:8px;padding-left:16px;position:relative;"><span style="position:absolute;left:0;color:var(--gold-primary);">›</span> Power consumption improvement / battery optimization</li>
            </ul>
            <a href="/en/rf-faq/" class="btn btn-outline" style="margin-top: 16px; padding: 6px 12px; font-size: 0.8rem; display: inline-flex; align-items: center; gap: 6px; width: fit-content; text-transform: uppercase; font-family: var(--font-mono);">
              <i class="fas fa-database"></i> View BLE Q&As
            </a>
          </div>
        </div>
      </div>

      <div class="grid-3">
        <div class="card">
          <i class="fas fa-wifi card-icon"></i>
          <h3>NFC / RFID Hardware</h3>
          <p>RFID/NFC system development with dual-frequency (125kHz + 13.56MHz) support.</p>
          <ul><li>125kHz low-frequency RFID design</li><li>13.56MHz NFC circuit design &amp; tuning</li><li>Dual antenna system development</li><li>Metal-environment NFC design</li></ul>
        </div>
        <div class="card">
          <i class="fas fa-wave-square card-icon"></i>
          <h3>Mixed-Signal Sensor Boards</h3>
          <p>Custom Mixed-Signal sensor boards for industrial, medical, and semiconductor equipment.</p>
          <ul><li>Analog front-end (AFE) design</li><li>High-resolution sensor interface design</li><li>Signal amplification / filtering / ADC optimization</li><li>MCU-based high-speed precision measurement</li></ul>
        </div>
        <div class="card">
          <i class="fas fa-industry card-icon"></i>
          <h3>Production · Test · Certification</h3>
          <p>Full lifecycle support from development to mass-production stabilization.</p>
          <ul><li>DFM design for manufacturability</li><li>Component selection &amp; BOM optimization</li><li>Production issue resolution</li><li>KC/FCC/CE certification guidance</li></ul>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
